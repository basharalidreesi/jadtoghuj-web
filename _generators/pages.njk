---js
{
	pagination: {
		data: "pages",
		alias: "page",
		size: 1,
		addAllPagesToCollections: true,
		before: function(paginationData) {
			const addresses = paginationData.filter(page => {
				return page.address
			})
			return addresses
		},
	},
	layout: "main.njk",
	tags: "page",
	permalink: "{{ settings.baseUrl }}{{ page.address }}/",
	eleventyComputed: {
		title: "{{ page.title | safe }}",
	},
}
---

		{%- if page.contents -%}
		{%- for block in page.contents %}
		<div class="{{ block.type | replaceCamelCase }}" {%- if block.type == "projectBlock" or block.type == "categoryBlock" %} data-size="{{ block.projects.length }}" {%- endif %}>
			{%- if block.type == "textBlock" %}
			{{ block.text | portableTextToHtml | safe }}
			{%- elif block.type == "imageBlock" %}
			<div class="image">
				{% sanityImage block.image %}
			</div>
			{%- elif block.type == "projectBlock" or block.type == "categoryBlock" -%}
			{%- for project in block.projects -%}
			{%- if project.image0 -%}
				{%- set image0 = "image" -%}
			{%- else -%}
				{%- set image0 = null -%}
			{%- endif -%}
			{%- if project.looks.length > 1 -%}
				{%- set looks = "looks" -%}
			{%- else -%}
				{%- set looks = null -%}
			{%- endif -%}
			{%- set contents = [image0, looks] %}
			<article class="project" {%- if project.isRepeated %} data-is-repeated="true" {% endif -%} data-contents="{{ contents.join(' ') | strip }}" {%- if image0 %} style="--colour-dominant-background: {{ project.image1.palette.background | default(project.image0.palette.background) }}; --colour-dominant-foreground: {{ project.image1.palette.foreground | default(project.image0.palette.foreground) }};" {%- endif %}>
				{%- if image0 %}
				<a class="project-link" href="{{ settings.baseUrl }}{{ settings.projectPath }}/{{ project.address }}/">
					<span>
						{{ project.title }}
					</span>
				</a>
				<div class="project-image" style="background-image: url({{ project.image1.lqip | default(project.image0.lqip) }}); background-repeat: no-repeat; background-size: auto 30rem; background-position: center;">
					{%- if project.isRepeated and project.image1 %}
					{% sanityImage project.image1 %}
					{%- else %}
					{% sanityImage project.image0 %}
					{%- endif %}
				</div>
				{%- endif -%}
				{%- if looks %}
				<div class="project-looks" data-size="{{ project.looks.length }}">
					{%- for look in project.looks %}
					<div class="project-look">
						{% sanityImage look %}
					</div>
					{%- endfor %}
				</div>
				{%- endif %}
			</article>
			{%- endfor -%}
			{%- elif block.type == "campaignBlock" %}
			{# campaign blocks #}
			{%- endif %}
		</div>
		{%- endfor -%}
		{%- endif %}
